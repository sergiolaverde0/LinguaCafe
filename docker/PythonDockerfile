FROM python:3.12-slim

WORKDIR /app
RUN apt-get update -y \
    && apt-get install -y --no-install-recommends tzdata \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN addgroup --gid 1000 laravel \
    && adduser --ingroup laravel --disabled-password --gecos "" --shell /bin/sh laravel
USER laravel

RUN pip3 install -U --no-cache-dir \
    torch --index-url https://download.pytorch.org/whl/cpu

RUN pip install -U --no-cache-dir \
        setuptools \
        wheel \
        lxml[html_clean] \
#youtube api
        youtube_transcript_api \
#ebook library
        ebooklib \
#kanji reading
        pykakasi \
#bottle
        bottle \
#spacy
        spacy \
#chinese reading
        pinyin \
#subtitle file parser
        pysub-parser \
#website text parser
        newspaper3k \
# stanza tokenizer
        stanza \
        spacy_stanza

RUN python3 -c 'import stanza; stanza.download("de", processors="tokenize,mwt,lemma")' \
    && python3 -m spacy download nb_core_news_sm \
    && python3 -c 'import stanza; stanza.download("es", processors="tokenize,mwt,lemma")' \
    && python3 -c 'import stanza; stanza.download("nl", processors="tokenize,mwt,lemma")' \
    && python3 -c 'import stanza; stanza.download("fi", processors="tokenize,mwt,lemma")' \
    && python3 -c 'import stanza; stanza.download("fr", processors="tokenize,mwt,lemma")' \
    && python3 -c 'import stanza; stanza.download("it", processors="tokenize,mwt,lemma")' \
    && python3 -m spacy download sv_core_news_sm \
    && python3 -c 'import stanza; stanza.download("en", processors="tokenize,mwt,lemma")' \
    && python3 -c 'import stanza; stanza.download("el", processors="tokenize,mwt,lemma")' \
    && python3 -c 'import stanza; stanza.download("ca", processors="tokenize,mwt,lemma")' \
    && python3 -m spacy download hr_core_news_sm \
    && python3 -m spacy download da_core_news_sm \
    && python3 -m spacy download lt_core_news_sm \
    && python3 -m spacy download mk_core_news_sm \
    && python3 -c 'import stanza; stanza.download("pl", processors="tokenize,mwt,lemma")' \
    && python3 -c 'import stanza; stanza.download("pt", processors="tokenize,mwt,lemma")' \
    && python3 -m spacy download ro_core_news_sm \
    && python3 -m spacy download sl_core_news_sm \
    && python3 -m spacy download xx_ent_wiki_sm

COPY ./tools /app

CMD [ "export PYTHONPATH=\"${HOME}/.local/bin:${PYTHONPATH}\"" ]
